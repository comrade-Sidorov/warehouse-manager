{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "WarehouseConnection":"Host=db;Port=5432; Username=warehouse; Password=warehouse;Database=warehouse"
  },
  "AllowedHosts": "*",
  "ApiSettings": {
    "Secret": "a-very-long-secret-key-for-hmac-sha256-that-is-32-bytes-long",
    "Issuer": "yourdomain.com",
    "Audience": "yourdomain.com"
  },

  "Kestrel": {
    "Endpoint": {
      "Http": {
        "Url": "http://localhost:5010"
      },
      "Https": {
        "Url": "https://localhost:7010"
      }
    }
  },
  "RevereseProxy":
  {
    "Routes": {
      "route-auth-service": {
        "ClusterId": "cluster-auth-service",
        "Match": {
          "Path": "/api/test"
        }
      }
    },
    "Clusters": {
      "cluster-auth-service": {
        "Destinations": {
          "destinations-auth-service": {
            "Address": "http://localhost:5002/api/test"
          }
        }
      }
    }
  }
}
